[Unit]
Description=Pterodactyl Honeyport Listener
After=network.target redis.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/pterodactyl
ExecStart=/usr/bin/php artisan security:honeyport:listen --ports=22222,23306,28080 --bind=0.0.0.0
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
